# Токен от @BotFather — обязателен для запуска
TELEGRAM_TOKEN=
BOT_USERNAME=vesbenzin_msk_bot

# Telegram user id админов через запятую (для /stats)
ADMIN_IDS=

DB_PATH=vesbenzin_data.db

# Опрос источников (сек)
POLL_INTERVAL_SEC=180

# Лимиты рассылки
NOTIFY_GLOBAL_RATE=25
NOTIFY_PER_CHAT_SEC=1.0
NOTIFY_COOLDOWN_HOURS=3
SNOOZE_HOURS=24

# Свежесть отметки и анти-дребезг статуса (мин)
STATUS_FRESH_MINUTES=45
STATUS_DEBOUNCE_MINUTES=8

# Укажите свою ссылку (CloudTips/ЮMoney/Telegram Stars и т.п.) — без неё кнопка доната скрыта
DONATE_URL=

# Telethon-аудит (research/run_audit.sh) — опционально
TG_API_ID=
TG_API_HASH=
TG_PHONE=+7...